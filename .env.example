# ============================================
# 彩虹易支付 Docker 环境变量配置
# 复制此文件为 .env 并修改
#   cp .env.example .env
# ============================================

# ---------- Nginx 端口 ----------
NGINX_PORT=80
# NGINX_SSL_PORT=443

# ---------- 数据库配置 ----------
DB_HOST=mysql
DB_PORT=3306
DB_USER=epay
DB_PASSWORD=修改为随机密码
DB_NAME=epay
DB_PREFIX=pay

# MySQL root 密码（仅首次初始化使用）
MYSQL_ROOT_PASSWORD=修改为随机密码

# 数据库端口暴露到宿主机（调试用，生产环境建议注释掉）
# DB_EXPOSE_PORT=33060

# ---------- 站点配置 ----------
SITE_URL=http://localhost
# SITE_URL=https://your-domain.com

# ---------- 管理员初始密码 ----------
# 首次安装时设置，安装后请立即登录后台修改
ADMIN_PASSWORD=修改为随机密码

# ---------- Cron 密钥 ----------
# 首次安装后通过以下方式获取，然后填入此处并重启 cron 容器
#   方法1: docker compose exec php cat /cron_key.txt
#   方法2: 登录后台 → 系统设置 → 安全设置 → 监控密钥
# 获取后执行: docker compose up -d cron
CRON_KEY=
